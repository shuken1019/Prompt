{
  "manifest_version": 3,
  "name": "Prompt Library Gemini Autofill",
  "version": "1.0.0",
  "description": "Autofills Gemini's prompt box from the Prompt Library app.",
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ]
}
